<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data transfer rules (android:dataExtractionRules).
  cloud-backup    -> Google cloud auto-backup.
  device-transfer -> device-to-device migration.
  Only lightweight user settings (SharedPreferences + DataStore) are included.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore" />
    </device-transfer>
</data-extraction-rules>
