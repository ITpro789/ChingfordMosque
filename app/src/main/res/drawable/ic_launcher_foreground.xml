<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher foreground: a modern mosque motif drawn on a 108x108
    viewport. All artwork is kept inside the central ~66dp safe zone
    (roughly x/y 21..87). Warm gold (#F4C95D) structures with white (#FFFFFF)
    highlights read cleanly against the deep emerald background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Crescent moon (top), difference of two circles via even-odd fill. -->
    <path
        android:fillColor="#F4C95D"
        android:fillType="evenOdd"
        android:pathData="M54,26 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 M57,24.5 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

    <!-- Finial pole connecting crescent to the dome. -->
    <path
        android:fillColor="#F4C95D"
        android:pathData="M53,33 L55,33 L55,40 L53,40 Z" />

    <!-- Central onion dome. -->
    <path
        android:fillColor="#F4C95D"
        android:pathData="M54,37 C50,42 46,47 46,53 C46,59 50,63 54,63 C58,63 62,59 62,53 C62,47 58,42 54,37 Z" />

    <!-- Soft white highlight on the dome. -->
